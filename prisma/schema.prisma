generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Decision {
  id          String   @id @default(cuid())
  type        String
  title       String
  note        String?
  monthlyCost Float    @default(0)
  startDate   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  secondOrder String?
  reclaim     String

  @@index([type])
  @@index([startDate])
}
